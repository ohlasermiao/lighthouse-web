---
import Base from '../../layouts/Base.astro';
import { PRICE } from '../../data/site';
---
<Base title="Pricing — Lighthouse Club" description="Lighthouse Club membership: about USD 60/month, billed every 3 months, no auto-charge, stop anytime." lang="en" routeKey="pricing">
  <div class="subpage">
    <div class="container narrow">
      <a class="back-link" href="/en/">← Back to home</a>
      <h1>Simple, transparent membership</h1>
      <p class="updated">One price · all channels included</p>

      <div class="price-card" style="margin:36px auto">
        <div class="plan">Membership</div>
        <div class="amount"><span class="cur">{PRICE.symbol}</span><span class="val">{PRICE.perMonth}</span><span class="per">/ mo</span></div>
        <div class="note">Billed {PRICE.symbol}{PRICE.total} every {PRICE.months} months · {PRICE.months}-month minimum<br />tax not included (applicable taxes vary by country/region)</div>
        <ul>
          <li>All member channels included</li>
          <li>Access granted after your application is approved</li>
          <li>Renewal reminder before expiry — no auto-charge</li>
          <li>Your membership status is always transparent</li>
        </ul>
        <a class="btn gold lg" href="/en/apply/" style="width:100%">Apply to join</a>
      </div>

      <h2>How renewal works</h2>
      <ul>
        <li><strong>No auto-charge</strong>: we remind you before expiry; renewing is always your own decision.</li>
        <li><strong>Stop anytime</strong>: simply don't renew — membership ends at the end of the paid period.</li>
        <li><strong>Payment methods</strong>: provided by email after your application is approved.</li>
      </ul>

      <h2>Refunds</h2>
      <ul>
        <li>Full refund within <strong>7 days</strong> of first activation.</li>
        <li>After 7 days, as access is delivered immediately, refunds are generally not provided.</li>
        <li>Full terms: <a href="/legal/tos/">Terms of Service</a> (Chinese, governing version) and <a href="/legal/tokushoho/">Legal Disclosure</a> (Japanese).</li>
      </ul>

      <p style="margin-top:48px" class="center"><a class="btn gold" href="/en/apply/">Apply to join →</a></p>
    </div>
  </div>
</Base>
