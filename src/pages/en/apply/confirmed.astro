---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
import { verifyApply } from '../../../lib/apply-token';

function env(key: string): string | undefined {
  return (Astro.locals as any)?.runtime?.env?.[key] ?? (import.meta.env as any)[key];
}
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

const url = Astro.url;
let state: 'ok' | 'invalid' | 'error' = url.searchParams.get('ok') === '1' ? 'ok' : 'error';

const token = url.searchParams.get('token');
if (token && state !== 'ok') {
  const key = env('RESEND_API_KEY');
  const secret = env('APPLY_SECRET') || key || '';
  const payload = await verifyApply(token, secret);
  if (!payload) {
    state = 'invalid';
  } else if (!key) {
    state = 'error';
  } else {
    // 申请已在提交时送达 hello@。此处只追一条"✓邮箱已确认"提示（供 Ethan 判断回信可达性）。
    const to = env('CONTACT_TO') || 'hello@sync-value.com';
    let when = '';
    try { when = new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Tokyo', dateStyle: 'medium', timeStyle: 'short' }).format(new Date()) + ' (JST)'; } catch {}
    const html = `<div style="font-family:-apple-system,'PingFang SC',sans-serif;font-size:14px;line-height:1.7;color:#232323;max-width:520px">
      <div style="background:#0f7a4d;color:#fff;padding:12px 18px;border-radius:10px 10px 0 0;font-weight:600">Lighthouse Club · <span>✓ 邮箱已确认</span> (EN)</div>
      <div style="border:1px solid #e6ebf1;border-top:0;border-radius:0 0 10px 10px;padding:16px 18px">
        <p style="margin:0 0 8px"><strong>${esc(payload.name)}</strong>（<a href="mailto:${esc(payload.email)}">${esc(payload.email)}</a>）刚刚确认了邮箱，<strong>回信可放心送达</strong>。</p>
        <p style="margin:0;color:#6b7a88;font-size:13px">对应此前那封"待确认"的入会申请。${when ? `确认时间 ${esc(when)}。` : ''}</p>
      </div>
    </div>`;
    try {
      const res = await fetch('https://api.resend.com/emails', {
        method: 'POST',
        headers: { Authorization: `Bearer ${key}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ from: 'Lighthouse Club <noreply@mail.sync-value.com>', to: [to], reply_to: payload.email, subject: `[入会申请·已确认✓·EN] ${payload.name}`, html }),
      });
      if (res.ok) return Astro.redirect('/en/apply/confirmed?ok=1');
      state = 'error';
    } catch { state = 'error'; }
  }
}
---
<Base title="Email confirmed — Lighthouse Club" description="Lighthouse Club application email confirmation." lang="en" noindex={true} routeKey="apply">
  <div class="subpage"><div class="container"><div class="account-box" style="max-width:520px">
    {state === 'ok' && (
      <Fragment>
        <div style="font-size:1.8rem">✅</div>
        <h1 style="margin:.3rem 0">Email confirmed — thank you!</h1>
        <p>We already received your application, and now your email is confirmed too — our decision will reach you for sure. We'll reply within <strong>2 business days</strong>; please keep an eye on your inbox (including spam).</p>
        <p class="fine" style="margin-top:16px"><a href="/en/">← Back to home</a></p>
      </Fragment>
    )}
    {state === 'invalid' && (
      <Fragment>
        <div style="font-size:1.8rem">⏳</div>
        <h1 style="margin:.3rem 0">Link invalid or expired</h1>
        <p>This confirmation link couldn't be verified — it may be older than 24 hours or already used. Don't worry: <strong>we already received your application</strong>; only the email confirmation didn't go through. To be sure you get our reply, you can apply again.</p>
        <p class="fine" style="margin-top:16px"><a class="btn gold" href="/en/apply/">Apply again</a></p>
      </Fragment>
    )}
    {state === 'error' && (
      <Fragment>
        <div style="font-size:1.8rem">😥</div>
        <h1 style="margin:.3rem 0">Something went wrong</h1>
        <p>A temporary error occurred during confirmation. Your application was already received and this step doesn't affect the review; you can click the link in your confirmation email again shortly, or <a href="/en/contact/">contact us</a>.</p>
      </Fragment>
    )}
  </div></div></div>
</Base>
