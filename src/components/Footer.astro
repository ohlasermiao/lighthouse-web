---
import { getLangFromUrl, useT, langPrefix } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useT(lang);
const p = langPrefix[lang];
const year = 2026;
const tagline = useT(lang)('footer.tagline').split('\n');
---
<footer class="site">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="fb-name">
          <img src="/assets/img/lighthouse.svg" alt="" width="28" height="28" />
          <span class="en">Lighthouse Club</span>
        </div>
        <div class="op">{tagline[0]}<br />{tagline[1]}</div>
      </div>
      <div class="footer-col">
        <h4>{t('footer.community')}</h4>
        <a href={lang === 'zh' ? '/about/' : p + '/about/'}>{t('nav.about')}</a>
        {lang === 'zh' && <a href="/inside/">{t('nav.inside')}</a>}
        <a href={lang === 'zh' ? '/pricing/' : p + '/pricing/'}>{t('nav.pricing')}</a>
        {lang === 'zh' && <a href="/faq/">{t('nav.faq')}</a>}
        <a href={lang === 'zh' ? '/apply/' : p + '/apply/'}>{t('nav.apply')}</a>
      </div>
      <div class="footer-col">
        <h4>{t('footer.support')}</h4>
        <a href="/my/">{t('footer.account')}</a>
        <a href={lang === 'zh' ? '/contact/' : p + '/contact/'}>{t('footer.contact')}</a>
        <a href="/news/">{t('footer.news')}</a>
      </div>
    </div>
    <div class="footer-legal">
      <a href="/legal/tos/">{t('legal.tos')}</a><span class="sep">·</span><a href="/legal/guidelines/">{t('legal.guidelines')}</a><span class="sep">·</span><a href="/legal/privacy/">{t('legal.privacy')}</a><span class="sep">·</span><a href="/legal/tokushoho/">{t('legal.tokushoho')}</a>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Syncvalue Inc.</span>
      <span>{t('footer.operator')}：<a href="https://sync-value.com/" rel="noopener noreferrer">シンクバリュー株式会社</a></span>
    </div>
  </div>
</footer>
