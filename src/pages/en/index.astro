---
import Base from '../../layouts/Base.astro';
import { PRICE, MEMBERS } from '../../data/site';
---
<Base title="Lighthouse Club — A membership community for Chinese speakers worldwide" description="A membership community for Chinese speakers worldwide — travel, food, daily news, pets, tarot and everyday life. Share real experience, meet your people." lang="en" routeKey="home">
  <div class="night">
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">Chinese speakers worldwide · Membership community</span>
          <h1 class="hero-title">Where thoughtful Chinese speakers<br /><span class="light">come together</span></h1>
          <p class="slogan-line">Lighthouse Club · be each other's light, on the sea of our times</p>
          <p class="hero-sub">Talk travel, share food, post your pets, follow the World Cup, read tarot, chat about daily life — share real experience, swap first-hand tips, and meet people you click with. {MEMBERS.en} paying members, lively every day.</p>
          <div class="hero-actions">
            <a class="btn gold lg" href="/en/apply/">Apply to join →</a>
            <a class="btn ghost-night lg" href="#inside">See what members talk about</a>
          </div>
          <div class="hero-trust">
            <span class="t"><b>Hundreds</b> of paying members</span>
            <span class="t"><b>Daily</b>active chat</span>
            <span class="t"><b>Many</b>life topics</span>
          </div>
        </div>
      </div>
    </section>
    <svg class="contour" viewBox="0 0 1440 70" preserveAspectRatio="none" aria-hidden="true" style="height:70px"><path d="M0,40 C240,70 480,8 720,32 C960,56 1200,14 1440,42 L1440,70 L0,70 Z" fill="#faf8f3"/></svg>
  </div>

  <section class="block" id="inside">
    <div class="container">
      <div class="sec-label">What members talk about</div>
      <h2 class="sec-title">A community, not a single topic</h2>
      <p class="sec-lead">All conversations are in Chinese. Channels evolve with members' interests and current events.</p>
      <div class="grid cols-4">
        <div class="card hue-star"><span class="chip">📰</span><h3>Daily News</h3><p>World Cup, headlines and observations from around the world.</p></div>
        <div class="card hue-gold"><span class="chip">✈️</span><h3>Travel</h3><p>Where to go and how to do it right — first-hand tips.</p></div>
        <div class="card hue-leaf"><span class="chip">🍜</span><h3>Food</h3><p>Share great eats, find good spots, where to buy.</p></div>
        <div class="card hue-tide"><span class="chip">🐾</span><h3>Pets</h3><p>Cats, dogs and the most healing corner of the community.</p></div>
      </div>
    </div>
  </section>

  <section class="block alt">
    <div class="container center">
      <div class="sec-label center">Membership</div>
      <h2 class="sec-title">Simple, transparent pricing</h2>
      <div class="price-card" style="margin-top:36px">
        <div class="plan">Membership</div>
        <div class="amount"><span class="cur">{PRICE.symbol}</span><span class="val">{PRICE.perMonth}</span><span class="per">/ mo</span></div>
        <div class="note">Billed {PRICE.symbol}{PRICE.total} every {PRICE.months} months · {PRICE.months}-month minimum · tax not included (varies by country)<br />No auto-charge — renewal always requires your confirmation · Stop anytime</div>
        <a class="btn gold lg" href="/en/apply/" style="width:100%">Apply to join</a>
        <p class="fine"><a href="/en/pricing/">Full pricing, renewal & refund details →</a></p>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="container">
      <div class="sec-label">How to join</div>
      <h2 class="sec-title">Three steps aboard</h2>
      <div class="steps" style="margin-top:36px">
        <div class="step"><div class="n">1</div><h3>Apply</h3><p>A short form — 4 questions, 3 minutes.</p></div>
        <div class="step"><div class="n">2</div><h3>Review</h3><p>We read every application and reply by email within 2 business days.</p></div>
        <div class="step"><div class="n">3</div><h3>Get invited</h3><p>Payment instructions, Discord invite and onboarding guide arrive by email.</p></div>
      </div>
    </div>
  </section>

  <div class="night flip">
    <section class="final-cta">
      <div class="container">
        <h2>The light stays on</h2>
        <p>Join {MEMBERS.en} members and find your people.</p>
        <a class="btn gold lg" href="/en/apply/">Apply to join →</a>
      </div>
    </section>
  </div>
</Base>
