---
import Base from '../../layouts/Base.astro';
import { PRICE } from '../../data/site';
---
<Base title="Apply — Lighthouse Club" description="Apply to join Lighthouse Club." lang="en" routeKey="apply">
  <div class="subpage">
    <div class="container apply-wrap">
      <a class="back-link" href="/en/">← Back to home</a>
      <h1>Apply to join Lighthouse Club</h1>
      <p style="margin-bottom:24px">We deliberately keep the community small — every application is read by a human to protect the quality of discussion. You'll hear back by email within <strong>2 business days</strong>; if approved, you'll receive payment instructions, a Discord invite and an onboarding guide. Note: community conversations are in Chinese.</p>

      <div class="apply-note" style="margin-bottom:26px">
        <strong>Already a member?</strong><br />
        Just <a href="/en/auth/login">log in</a> to see your membership status — no need to apply again.
      </div>

      <form id="apply-form" action="/api/apply" method="POST">
        <input type="hidden" name="lang" value="en" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-field">
          <label for="a-name">What should we call you? *</label>
          <input type="text" id="a-name" name="name" required placeholder="Nickname" autocomplete="nickname" />
        </div>
        <div class="form-field">
          <label for="a-email">Email *</label>
          <input type="email" id="a-email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <div class="hint">Our decision goes to this address, so please check it's correct. After you submit we'll also send a confirmation email — one click makes sure our reply reaches you.</div>
        </div>
        <div class="form-field">
          <label for="a-motivation">In one sentence: what do you hope to get from the community? *</label>
          <textarea id="a-motivation" name="motivation" required placeholder="Making friends, learning, finding direction — anything goes"></textarea>
        </div>
        <div class="form-field">
          <label for="a-source">How did you hear about us? <span style="font-weight:400">(optional)</span></label>
          <input type="text" id="a-source" name="source" placeholder="Friend / social media / other" />
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADt8PjE4JgY0PwSh" style="margin:14px 0"></div>
        <div class="form-actions">
          <button class="btn gold" type="submit" id="apply-submit">Submit application</button>
          <p class="fine">By submitting you agree to our <a href="/legal/tos/">Terms</a> and <a href="/legal/privacy/">Privacy Policy</a> (Chinese, governing).</p>
          <p class="form-error" id="apply-error">Submission failed — please check your email is correct, or try again shortly.</p>
        </div>
      </form>

      <div class="form-success" id="apply-success">
        <div id="apply-pending">
          <h2 style="margin-top:0">One step left: verify your email 📩</h2>
          <p>Your application <strong>isn't submitted yet</strong>. We've sent a verification email to <strong id="apply-email"></strong> — please open it and click <strong>"Verify my email &amp; submit"</strong> so your application reaches us.</p>
          <div class="form-actions" style="margin-top:6px">
            <button type="button" class="btn gold" id="apply-check">Complete email verification</button>
            <p class="fine" id="apply-check-hint" style="display:none;color:#c0392b"></p>
          </div>
          <p class="fine" style="margin-top:14px;color:var(--ink-3)">Didn't get it? Check spam, or <a href="/en/apply/">apply again</a>. This page updates automatically once you verify in the email.</p>
        </div>
        <div id="apply-done" style="display:none">
          <h2 style="margin-top:0">Email verified — application submitted! ✅</h2>
          <p>You're all set. We'll read it carefully and reply within <strong>2 business days</strong> to your email (check spam too).</p>
          <p style="margin-bottom:0"><a href="/en/">← Back to home</a></p>
        </div>
      </div>

      <div class="apply-note">
        <strong>Before you join</strong><br />
        Joining means agreeing to our <a href="/legal/guidelines/">Community Guidelines</a>: share experience over conclusions, treat each other kindly, don't redistribute member-only content. Membership is {PRICE.symbol}{PRICE.perMonth}/month (billed {PRICE.symbol}{PRICE.total} every {PRICE.months} months); payment instructions follow approval — no auto-charge, renewal is always your decision.
      </div>
    </div>
  </div>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    const form = document.getElementById('apply-form') as HTMLFormElement;
    const success = document.getElementById('apply-success') as HTMLElement;
    const error = document.getElementById('apply-error') as HTMLElement;
    const btn = document.getElementById('apply-submit') as HTMLButtonElement;
    const pending = document.getElementById('apply-pending') as HTMLElement;
    const done = document.getElementById('apply-done') as HTMLElement;
    const emailEl = document.getElementById('apply-email') as HTMLElement;
    const checkBtn = document.getElementById('apply-check') as HTMLButtonElement;
    const hint = document.getElementById('apply-check-hint') as HTMLElement;
    let statusToken = '';
    let pollTimer: any = null;

    function showDone() {
      if (pollTimer) clearInterval(pollTimer);
      pending.style.display = 'none';
      done.style.display = 'block';
    }
    async function checkStatus(): Promise<string | null> {
      if (!statusToken) return null;
      try {
        const r = await fetch('/api/apply/status?token=' + encodeURIComponent(statusToken));
        const j = await r.json();
        return j.status;
      } catch { return null; }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      error.style.display = 'none';
      btn.disabled = true;
      btn.textContent = 'Submitting…';
      const emailVal = (form.elements.namedItem('email') as HTMLInputElement)?.value || '';
      fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } })
        .then((res) => res.ok ? res.json() : Promise.reject(new Error('bad status')))
        .then((j) => {
          statusToken = j.status_token || '';
          emailEl.textContent = emailVal;
          form.style.display = 'none';
          success.style.display = 'block';
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          if (statusToken) {
            pollTimer = setInterval(async () => {
              if (await checkStatus() === 'confirmed') showDone();
            }, 4000);
          }
        })
        .catch(() => {
          error.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Submit application';
          if ((window as any).turnstile) (window as any).turnstile.reset();
        });
    });

    checkBtn.addEventListener('click', async () => {
      checkBtn.disabled = true;
      checkBtn.textContent = 'Checking…';
      const s = await checkStatus();
      if (s === 'confirmed') { showDone(); return; }
      hint.style.display = 'block';
      hint.textContent = 'Not verified yet — please open the email we sent you and click "Verify my email & submit" first.';
      checkBtn.disabled = false;
      checkBtn.textContent = 'Complete email verification';
    });
  </script>
</Base>
