---
import Base from '../../layouts/Base.astro';
---
<Base title="Lighthouse Club — Find your crew on the sea of our times" description="A membership community for global Chinese youth: AI, going global, studying abroad, careers, life — sharing real experience and first-hand observations." lang="en" routeKey="home">
  <div class="night">
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">Global Chinese youth · Membership community</span>
          <h1 class="hero-title">On the sea of our times,<br />find <span class="light">your crew</span></h1>
          <p class="hero-sub">AI, going global, studying abroad, new careers, new opportunities — the waves keep coming, and no one can watch them all alone. Lighthouse Club brings together 700+ Chinese-speaking young people around the world: sharing real experience, exchanging first-hand observations, finding light in each other.</p>
          <div class="hero-actions">
            <a class="btn gold lg" href="/en/apply/">Apply to join →</a>
            <a class="btn ghost-night lg" href="/en/about/">What is this</a>
          </div>
          <div class="hero-trust">
            <span class="t"><b>700+</b>paying members</span>
            <span class="t"><b>7</b>channels</span>
            <span class="t"><b>Daily</b>active discussions</span>
          </div>
        </div>
      </div>
    </section>
    <svg class="contour" viewBox="0 0 1440 70" preserveAspectRatio="none" aria-hidden="true" style="height:70px"><path d="M0,40 C240,70 480,8 720,32 C960,56 1200,14 1440,42 L1440,70 L0,70 Z" fill="#faf8f3"/></svg>
  </div>

  <section class="block">
    <div class="container">
      <div class="sec-label">What members talk about</div>
      <h2 class="sec-title">Seven channels, one community</h2>
      <p class="sec-lead">All conversations are in Chinese. Channels grow with the community.</p>
      <div class="grid cols-4">
        <div class="card hue-star"><span class="chip">🤖</span><h3>AI & Tech</h3><p>New tools, new possibilities — first-hand experience.</p></div>
        <div class="card hue-gold"><span class="chip">✈️</span><h3>Study & Go Global</h3><p>Applications, visas, and life abroad from people who've done it.</p></div>
        <div class="card hue-leaf"><span class="chip">💼</span><h3>Careers</h3><p>Internships, job hunting, side projects, industry watch.</p></div>
        <div class="card hue-tide"><span class="chip">🌱</span><h3>Life & Hobbies</h3><p>Cities, food, hobbies — meet people on the same wavelength.</p></div>
      </div>
    </div>
  </section>

  <section class="block alt">
    <div class="container center">
      <div class="sec-label center">Membership</div>
      <h2 class="sec-title">Simple, transparent pricing</h2>
      <div class="price-card" style="margin-top:36px">
        <div class="plan">Quarterly</div>
        <div class="amount"><span class="cur">$</span><span class="val">180</span><span class="per">/ 3 months</span></div>
        <div class="note">≈ $60/month · tax not included (varies by country)<br />No auto-charge — renewal always requires your confirmation · Stop anytime</div>
        <a class="btn gold lg" href="/en/apply/" style="width:100%">Apply to join</a>
        <p class="fine"><a href="/en/pricing/">Full pricing, renewal & refund details →</a></p>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="container">
      <div class="sec-label">How to join</div>
      <h2 class="sec-title">Three steps aboard</h2>
      <div class="steps" style="margin-top:36px">
        <div class="step"><div class="n">1</div><h3>Apply</h3><p>A short form — 4 questions, 3 minutes.</p></div>
        <div class="step"><div class="n">2</div><h3>Review</h3><p>We read every application and reply by email within 2 business days.</p></div>
        <div class="step"><div class="n">3</div><h3>Get invited</h3><p>Payment instructions, Discord invite and onboarding guide arrive by email.</p></div>
      </div>
    </div>
  </section>

  <div class="night flip">
    <section class="final-cta">
      <div class="container">
        <h2>The light stays on</h2>
        <p>Join 700+ members sailing the same sea.</p>
        <a class="btn gold lg" href="/en/apply/">Apply to join →</a>
      </div>
    </section>
  </div>
</Base>
