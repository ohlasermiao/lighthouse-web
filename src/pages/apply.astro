---
import Base from '../layouts/Base.astro';
import { PRICE } from '../data/site';
---
<Base title="申请加入 — Lighthouse Club" description="申请加入 Lighthouse Club——面向全球华人的会员制生活交流社区。" routeKey="apply">
  <div class="subpage">
    <div class="container apply-wrap">
      <a class="back-link" href="/">← 返回首页</a>
      <h1>申请加入 Lighthouse Club</h1>
      <p style="margin-bottom:28px">我们刻意保持小规模——每一位成员的申请都会被认真阅读，以保证讨论的质量和社区的氛围。提交后 <strong>2 个工作日内</strong>，我们会把结果回复到你的邮箱；通过后你会收到付款方式、Discord 邀请与入门指引。</p>

      <form id="apply-form" action="https://formspree.io/f/mqeoygjz" method="POST">
        <input type="hidden" name="_subject" value="Lighthouse Club 入会申请" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-field">
          <label for="f-name">怎么称呼你？</label>
          <input type="text" id="f-name" name="name" required placeholder="昵称或称呼" autocomplete="nickname" />
        </div>
        <div class="form-field">
          <label for="f-email">邮箱</label>
          <input type="email" id="f-email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <div class="hint">审核结果将发送到这个邮箱，请确认无误。</div>
        </div>
        <div class="form-field">
          <label for="f-motivation">一句话：你希望从社区获得什么？</label>
          <textarea id="f-motivation" name="motivation" required placeholder="随便聊聊——交朋友、学东西、找方向、找个能安心说话的地方，都可以"></textarea>
        </div>
        <div class="form-field">
          <label for="f-source">从哪里了解到我们？<span style="font-weight:400">（选填）</span></label>
          <input type="text" id="f-source" name="source" placeholder="朋友推荐 / 社交媒体 / 其他" />
        </div>
        <div class="form-actions">
          <button class="btn gold" type="submit" id="apply-submit">提交申请</button>
          <p class="fine">提交即表示同意 <a href="/legal/tos/">服务条款</a> 与 <a href="/legal/privacy/">隐私政策</a></p>
          <p class="form-error" id="apply-error">提交没有成功，请稍后再试，或通过<a href="/contact/">联系我们</a>页面留言。</p>
        </div>
      </form>

      <div class="form-success" id="apply-success">
        <h2 style="margin-top:0">已收到你的申请 🎉</h2>
        <p>我们会认真阅读每一份申请，并在 <strong>2 个工作日内</strong>回复到你的邮箱，请留意收件箱（包括垃圾箱）。</p>
        <p style="margin-bottom:0"><a href="/">← 回到首页</a></p>
      </div>

      <div class="apply-note">
        <strong>加入须知</strong><br />
        加入即表示同意<a href="/legal/guidelines/">社区公约</a>：分享经历胜过给结论、互相尊重、不传播会员专属内容。会员费 {PRICE.symbol}{PRICE.perMonth}/月（{PRICE.months} 个月一期、每期 {PRICE.symbol}{PRICE.total}），审核通过后我们会在邮件中说明付款方式——到期不自动扣款，续费始终由你决定。
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('apply-form') as HTMLFormElement;
    const success = document.getElementById('apply-success')!;
    const error = document.getElementById('apply-error')!;
    const btn = document.getElementById('apply-submit') as HTMLButtonElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      error.style.display = 'none';
      btn.disabled = true;
      btn.textContent = '提交中…';
      fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } })
        .then((res) => {
          if (res.ok) {
            form.style.display = 'none';
            (success as HTMLElement).style.display = 'block';
            success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else throw new Error('bad status');
        })
        .catch(() => {
          (error as HTMLElement).style.display = 'block';
          btn.disabled = false;
          btn.textContent = '提交申请';
        });
    });
  </script>
</Base>
