---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { supabaseServer } from '../../lib/supabase';

const supabase = supabaseServer(Astro.cookies, Astro.request.headers);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/en/auth/login');

// Self-service: security-definer function, returns only the caller's (auth.email()) membership.
const { data: rows } = await supabase.rpc('my_membership');
const m = Array.isArray(rows) && rows.length ? rows[0] : null;

const hasAccount = !!m?.has_account;
const discordLinked = !!m?.discord_linked;
const tier = m?.tier as string | null;
const status = m?.status as string | null;
const expiresAt = m?.expires_at ? new Date(m.expires_at as string) : null;
const channel = m?.payment_channel as string | null;

const isActive = status === 'active' && !!expiresAt && expiresAt.getTime() > Date.now();
const daysLeft = expiresAt ? Math.ceil((expiresAt.getTime() - Date.now()) / 86400000) : null;
const fmt = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
const channelLabel: Record<string, string> = {
  alipay: 'Alipay', wechat: 'WeChat', wise: 'Wise', crypto: 'Crypto',
  comp: 'Complimentary', legacy: 'Legacy record',
};
---
<Base title="Member center — Lighthouse Club" description="Lighthouse Club member center." lang="en" noindex={true} routeKey="my">
  <div class="subpage">
    <div class="container">
      <div class="account-box" style="text-align:left">
        <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
          <h1 style="margin:0">Member center</h1>
          <a class="btn" href="/auth/signout" style="font-size:.82rem;padding:6px 14px">Sign out</a>
        </div>
        <p style="color:var(--ink-3);font-size:.95rem;margin:.3rem 0 1.2rem">{user.email}</p>

        {!hasAccount && (
          <div class="status-card" style="border:1px solid var(--line,#2a3550);border-radius:14px;padding:20px">
            <p>Your email isn't linked to a member account yet. If you're already a community member, verify your identity with Discord to link them.</p>
            <a class="btn gold" href="/auth/discord" style="margin-top:10px">Verify with Discord</a>
          </div>
        )}

        {hasAccount && (
          <div class="status-card" style="border:1px solid var(--line,#2a3550);border-radius:14px;padding:22px">
            {isActive ? (
              <Fragment>
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
                  <span style="font-size:1.6rem">✨</span>
                  <strong style="font-size:1.15rem">{tier === 'FAN' ? 'FAN member' : 'VIP member'}</strong>
                  <span style="margin-left:auto;color:#1e9e64;font-weight:600;font-size:.85rem">Active</span>
                </div>
                <div style="display:grid;grid-template-columns:auto 1fr;gap:10px 16px;font-size:1rem">
                  <span style="color:var(--ink-3)">Expires</span><span>{expiresAt && fmt(expiresAt)} ({daysLeft} days left)</span>
                  {channel && <Fragment><span style="color:var(--ink-3)">Last payment method</span><span>{channelLabel[channel] ?? channel}</span></Fragment>}
                </div>
                <p class="fine" style="margin-top:16px;color:var(--ink-3);font-size:.82rem">Self-service renewal is coming soon. We'll remind you before expiry; to renew early, please <a href="/en/contact/">contact us</a>.</p>
              </Fragment>
            ) : (
              <Fragment>
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
                  <span style="font-size:1.6rem">⏳</span>
                  <strong style="font-size:1.1rem">{discordLinked ? 'No active subscription' : 'Account linked'}</strong>
                </div>
                <p>{discordLinked ? 'You don\'t have an active membership right now — it may have expired.' : 'Account linked, but no Discord binding detected yet.'}</p>
                {!discordLinked && <a class="btn" href="/auth/discord" style="margin-top:10px">Link Discord</a>}
                <p class="fine" style="margin-top:14px;color:var(--ink-3);font-size:.82rem">Need to renew or get help? Please <a href="/en/contact/">contact us</a>.</p>
              </Fragment>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</Base>
