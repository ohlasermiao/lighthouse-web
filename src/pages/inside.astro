---
import Base from '../layouts/Base.astro';

const boards = [
  { icon: '📰', name: '今日见闻', desc: '世界杯、热点、各地见闻与日常观察，换个视角看世界。', eg: '最近在聊：世界杯战况、各地趣闻、身边新鲜事' },
  { icon: '✈️', name: '旅行攻略', desc: '去哪玩、怎么玩、怎么省心——过来人的一手攻略与避坑。', eg: '最近在聊：行程怎么排、订票订房、当地吃住行' },
  { icon: '🍜', name: '大众美食', desc: '晒美食、找好店，分享在哪吃、在哪买、怎么做。', eg: '最近在聊：探店晒图、家常菜、值得囤的零食' },
  { icon: '🐾', name: '萌宠治愈', desc: '晒猫晒狗晒一切，社区里最治愈的角落。', eg: '最近在聊：晒主子、养宠经验、云吸猫狗' },
  { icon: '🔮', name: '玄学塔罗', desc: '塔罗、周易、星座，给日常添一点好奇与乐趣。', eg: '最近在聊：新月许愿、每日运势、牌阵解读' },
  { icon: '💬', name: '自由闲聊', desc: '没有主题的主题区——随便聊聊，认识同频的人。', eg: '最近在聊：今天吃了啥、深夜碎碎念、周末去哪' },
  { icon: '✨', name: '新板块孵化中', desc: '板块会随社区兴趣与时事不断生长。你想聊的话题聚集到足够的人，就会成为下一个板块。', eg: '想开新板块？进群后直接提议' },
];
---
<Base title="社区板块 — Lighthouse Club" description="Lighthouse Club 的社区板块：今日见闻、旅行攻略、大众美食、萌宠治愈、玄学塔罗、自由闲聊。" routeKey="inside">
  <div class="subpage">
    <div class="container narrow">
      <a class="back-link" href="/">← 返回首页</a>
      <h1>大家都在聊什么</h1>
      <p class="updated">板块会随社区兴趣与时事不断调整——下面是当前的活跃板块，在你感兴趣的频道随心参与。</p>

      <div style="margin-top:20px">
        {boards.map((b) => (
          <div class="board-row">
            <span class="chip">{b.icon}</span>
            <div>
              <h3>{b.name}</h3>
              <p>{b.desc}</p>
              <div class="eg">{b.eg}</div>
            </div>
          </div>
        ))}
      </div>

      <p style="margin-top:48px" class="center"><a class="btn gold" href="/apply/">申请加入，进入全部板块 →</a></p>
    </div>
  </div>
</Base>
