---
import Base from '../layouts/Base.astro';

const boards = [
  { icon: '🤖', name: 'AI · 科技前沿', desc: '新模型、新工具、新玩法的第一手体验与讨论。谁先用上，谁先看懂下一波。', eg: '最近在聊：AI 编程工具实测、提示词技巧、行业落地案例' },
  { icon: '✈️', name: '留学 · 出海', desc: '申请、签证、落地生活的一手经验。住在世界各地的伙伴，把走过的弯路画成你的近道。', eg: '最近在聊：选校与文书、各国签证时间线、海外第一个月生存指南' },
  { icon: '💼', name: '职业 · 机会', desc: '实习、求职、跳槽、副业与行业观察。把看到的机会聊给彼此听。', eg: '最近在聊：面试复盘、远程工作机会、行业冷暖一线观察' },
  { icon: '🌱', name: '生活 · 兴趣', desc: '城市、美食、旅行、爱好与日常。轻松认识同频的人。', eg: '最近在聊：城市生活成本、健身打卡、晒猫晒狗晒晚饭' },
  { icon: '📚', name: '学习 · 成长', desc: '读书、技能、经验交流——把彼此的所学带到一起，互相启发。', eg: '最近在聊：共读一本书、语言学习方法、效率工具' },
  { icon: '📈', name: '市场观察', desc: '聊聊行情、宏观与身边的经济话题，交换彼此的观察。', eg: '最近在聊：宏观新闻怎么看、各国物价与汇率体感' },
  { icon: '🔮', name: '玄学 · 塔罗周易', desc: '东西方的神秘文化——塔罗、周易、星座，给日常添一点好奇与乐趣。', eg: '最近在聊：新月许愿、年运牌阵、周易入门' },
  { icon: '✨', name: '新板块孵化中', desc: '板块由社区共同生长。你想聊的话题聚集到足够的人，就会成为下一个板块。', eg: '想开新板块？进群后直接提议' },
];
---
<Base title="社区板块 — Lighthouse Club" description="Lighthouse Club 的七大板块：AI 科技、留学出海、职业机会、生活兴趣、学习成长、市场观察、玄学塔罗。" routeKey="inside">
  <div class="subpage">
    <div class="container narrow">
      <a class="back-link" href="/">← 返回首页</a>
      <h1>大家都在聊什么</h1>
      <p class="updated">七大板块随社区一起生长 · 在你感兴趣的频道随心参与</p>

      <div style="margin-top:20px">
        {boards.map((b) => (
          <div class="board-row">
            <span class="chip">{b.icon}</span>
            <div>
              <h3>{b.name}</h3>
              <p>{b.desc}</p>
              <div class="eg">{b.eg}</div>
            </div>
          </div>
        ))}
      </div>

      <p style="margin-top:48px" class="center"><a class="btn gold" href="/apply/">申请加入，进入全部板块 →</a></p>
    </div>
  </div>
</Base>
