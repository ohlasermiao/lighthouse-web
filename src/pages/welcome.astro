---
import Base from '../layouts/Base.astro';
---
<Base title="欢迎加入 — Lighthouse Club" description="欢迎加入 Lighthouse Club。" noindex={true}>
  <div class="subpage">
    <div class="container">
      <div class="account-box">
        <div class="ic">🎉</div>
        <h1>欢迎加入 Lighthouse Club！</h1>
        <p>你的会员已开通。下一步，进入社区，和大家一起开始交流吧。</p>
        <a class="btn gold" href="https://discord.gg/ShujumgQ" rel="noopener noreferrer" data-discord-link>进入社区频道 →</a>
        <p class="fine" style="margin-top:18px;color:var(--ink-3);font-size:.82rem">
          如果没有自动跳转，请通过你收到的邮件指引进入社区；遇到问题可发邮件至 <a href="mailto:hello@sync-value.com">hello@sync-value.com</a> 或在社区内官方渠道求助。
        </p>
      </div>
    </div>
  </div>
</Base>
