---
import Base from '../layouts/Base.astro';
import { PRICE } from '../data/site';
---
<Base title="申请加入 — Lighthouse Club" description="申请加入 Lighthouse Club——面向全球华人的会员制生活交流社区。" routeKey="apply">
  <div class="subpage">
    <div class="container apply-wrap">
      <a class="back-link" href="/">← 返回首页</a>
      <h1>申请加入 Lighthouse Club</h1>
      <p style="margin-bottom:24px">我们刻意保持小规模——每一位成员的申请都会被认真阅读，以保证讨论的质量和社区的氛围。提交后 <strong>2 个工作日内</strong>，我们会把结果回复到你的邮箱；通过后你会收到付款方式、Discord 邀请与入门指引。</p>

      <div class="apply-note" style="margin-bottom:26px">
        <strong>已经是会员？</strong><br />
        直接<a href="/auth/login">登录</a>查看你的会员状态，无需再次申请。
      </div>

      <form id="apply-form" action="/api/apply" method="POST">
        <input type="hidden" name="lang" value="zh" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-field">
          <label for="a-name">怎么称呼你？ *</label>
          <input type="text" id="a-name" name="name" required placeholder="昵称或称呼" autocomplete="nickname" />
        </div>
        <div class="form-field">
          <label for="a-email">邮箱 *</label>
          <input type="email" id="a-email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <div class="hint">审核结果会回复到这个邮箱，请确认无误。提交后我们还会发一封确认信，点一下就能确保回复送得到。</div>
        </div>
        <div class="form-field">
          <label for="a-motivation">一句话：你希望从社区获得什么？ *</label>
          <textarea id="a-motivation" name="motivation" required placeholder="交朋友、学东西、找方向、找个能安心说话的地方，都可以"></textarea>
        </div>
        <div class="form-field">
          <label for="a-source">从哪里了解到我们？<span style="font-weight:400">（选填）</span></label>
          <input type="text" id="a-source" name="source" placeholder="朋友推荐 / 社交媒体 / 其他" />
        </div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADt8PjE4JgY0PwSh" style="margin:14px 0"></div>
        <div class="form-actions">
          <button class="btn gold" type="submit" id="apply-submit">提交申请</button>
          <p class="fine">提交即表示同意 <a href="/legal/tos/">服务条款</a> 与 <a href="/legal/privacy/">隐私政策</a></p>
          <p class="form-error" id="apply-error">提交没有成功——请检查邮箱是否填写正确，或稍后再试。</p>
        </div>
      </form>

      <div class="form-success" id="apply-success">
        <div id="apply-pending">
          <h2 style="margin-top:0">还差一步：验证你的邮箱 📩</h2>
          <p>你的申请<strong>还没有提交成功</strong>。我们给 <strong id="apply-email"></strong> 发了一封验证邮件——请打开邮箱、点击里面的<strong>「验证邮箱并提交申请」</strong>按钮，你的申请才会正式送到我们手上。</p>
          <div class="form-actions" style="margin-top:6px">
            <button type="button" class="btn gold" id="apply-check">完成邮箱验证</button>
            <p class="fine" id="apply-check-hint" style="display:none;color:#c0392b"></p>
          </div>
          <p class="fine" style="margin-top:14px;color:var(--ink-3)">没收到？检查垃圾箱，或<a href="/apply/">重新申请</a>。你在邮件里完成验证后，本页面会自动更新。</p>
        </div>
        <div id="apply-done" style="display:none">
          <h2 style="margin-top:0">邮箱已验证，申请已提交！✅</h2>
          <p>手续全部完成。我们会认真阅读，并在 <strong>2 个工作日内</strong>把结果回复到你的邮箱，请留意收件箱（包括垃圾箱）。</p>
          <p style="margin-bottom:0"><a href="/">← 回到首页</a></p>
        </div>
      </div>

      <div class="apply-note">
        <strong>加入须知</strong><br />
        加入即表示同意<a href="/legal/guidelines/">社区公约</a>：分享经历胜过给结论、互相尊重、不传播会员专属内容。会员费 {PRICE.symbol}{PRICE.perMonth}/月（{PRICE.months} 个月一期、每期 {PRICE.symbol}{PRICE.total}），审核通过后我们会在邮件中说明付款方式——到期不自动扣款，续费始终由你决定。
      </div>
    </div>
  </div>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    const form = document.getElementById('apply-form') as HTMLFormElement;
    const success = document.getElementById('apply-success') as HTMLElement;
    const error = document.getElementById('apply-error') as HTMLElement;
    const btn = document.getElementById('apply-submit') as HTMLButtonElement;
    const pending = document.getElementById('apply-pending') as HTMLElement;
    const done = document.getElementById('apply-done') as HTMLElement;
    const emailEl = document.getElementById('apply-email') as HTMLElement;
    const checkBtn = document.getElementById('apply-check') as HTMLButtonElement;
    const hint = document.getElementById('apply-check-hint') as HTMLElement;
    let statusToken = '';
    let pollTimer: any = null;

    function showDone() {
      if (pollTimer) clearInterval(pollTimer);
      pending.style.display = 'none';
      done.style.display = 'block';
    }
    async function checkStatus(): Promise<string | null> {
      if (!statusToken) return null;
      try {
        const r = await fetch('/api/apply/status?token=' + encodeURIComponent(statusToken));
        const j = await r.json();
        return j.status;
      } catch { return null; }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      error.style.display = 'none';
      btn.disabled = true;
      btn.textContent = '提交中…';
      const emailVal = (form.elements.namedItem('email') as HTMLInputElement)?.value || '';
      fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } })
        .then((res) => res.ok ? res.json() : Promise.reject(new Error('bad status')))
        .then((j) => {
          statusToken = j.status_token || '';
          emailEl.textContent = emailVal;
          form.style.display = 'none';
          success.style.display = 'block';
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
          if (statusToken) {
            pollTimer = setInterval(async () => {
              if (await checkStatus() === 'confirmed') showDone();
            }, 4000);
          }
        })
        .catch(() => {
          error.style.display = 'block';
          btn.disabled = false;
          btn.textContent = '提交申请';
          if ((window as any).turnstile) (window as any).turnstile.reset();
        });
    });

    checkBtn.addEventListener('click', async () => {
      checkBtn.disabled = true;
      checkBtn.textContent = '检查中…';
      const s = await checkStatus();
      if (s === 'confirmed') { showDone(); return; }
      hint.style.display = 'block';
      hint.textContent = '还没检测到验证完成——请先打开我们发到你邮箱的邮件，点里面的「验证邮箱并提交申请」按钮。';
      checkBtn.disabled = false;
      checkBtn.textContent = '完成邮箱验证';
    });
  </script>
</Base>
