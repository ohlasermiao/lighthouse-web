---
import Base from '../layouts/Base.astro';

const boards = [
  { icon: '🎓', name: '升学教育', desc: '在日本择校升学的一手经验——国际学校、私立中小学、升学路径与补习资源。过来人帮你少走弯路。', eg: '最近在聊：国际学校怎么选、插班与考试、补习班口碑' },
  { icon: '✈️', name: '旅日攻略', desc: '来日本玩的实用攻略——热门去处、订票订房、交通与支付，怎样合法又省心地玩。', eg: '最近在聊：赏枫路线、JR Pass 值不值、热门餐厅怎么订' },
  { icon: '🛍️', name: '日本好物', desc: '分享日本值得买的东西，以及在哪能买到。纯交流种草，不做代购。', eg: '最近在聊：药妆必囤、家电对比、限定零食' },
  { icon: '🌏', name: '世界见闻', desc: '世界各地的见闻、热门赛事与文化话题，换个视角看世界。', eg: '最近在聊：世界杯战况、各地趣闻、文化观察' },
  { icon: '🔮', name: '玄学塔罗', desc: '东西方的神秘文化——塔罗、周易、星座，给日常添一点好奇与乐趣。', eg: '最近在聊：新月许愿、年运牌阵、周易入门' },
  { icon: '🐾', name: '阿猫阿狗', desc: '晒宠物、云吸猫狗，社区里最治愈的角落。', eg: '最近在聊：晒主子、养宠经验、领养信息' },
  { icon: '💬', name: '自由闲聊', desc: '没有主题的主题区——日常吐槽、随便聊聊，认识同频的人。', eg: '最近在聊：今天吃了啥、深夜碎碎念、周末去哪' },
  { icon: '✨', name: '新板块孵化中', desc: '板块由社区共同生长。你想聊的话题聚集到足够的人，就会成为下一个板块。', eg: '想开新板块？进群后直接提议' },
];
---
<Base title="社区板块 — Lighthouse Club" description="Lighthouse Club 的社区板块：升学教育、旅日攻略、日本好物、世界见闻、玄学塔罗、阿猫阿狗、自由闲聊。" routeKey="inside">
  <div class="subpage">
    <div class="container narrow">
      <a class="back-link" href="/">← 返回首页</a>
      <h1>大家都在聊什么</h1>
      <p class="updated">七大板块随社区一起生长 · 在你感兴趣的频道随心参与</p>

      <div style="margin-top:20px">
        {boards.map((b) => (
          <div class="board-row">
            <span class="chip">{b.icon}</span>
            <div>
              <h3>{b.name}</h3>
              <p>{b.desc}</p>
              <div class="eg">{b.eg}</div>
            </div>
          </div>
        ))}
      </div>

      <p style="margin-top:48px" class="center"><a class="btn gold" href="/apply/">申请加入，进入全部板块 →</a></p>
    </div>
  </div>
</Base>
