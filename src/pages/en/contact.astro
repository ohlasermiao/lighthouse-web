---
import Base from '../../layouts/Base.astro';
---
<Base title="Contact — Lighthouse Club" description="Contact the Lighthouse Club team." lang="en" routeKey="contact">
  <div class="subpage">
    <div class="container apply-wrap">
      <a class="back-link" href="/en/">← Back to home</a>
      <h1>Contact us</h1>
      <p style="margin-bottom:28px">Questions about membership, payment or the community — leave a message and we'll usually reply within 1 business day.</p>

      <form id="contact-form" action="/api/contact" method="POST">
        <input type="hidden" name="_subject" value="Lighthouse Club contact (EN)" />
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div class="form-field">
          <label for="c-name">Name</label>
          <input type="text" id="c-name" name="name" required placeholder="How should we address you" autocomplete="nickname" />
        </div>
        <div class="form-field">
          <label for="c-email">Email</label>
          <input type="email" id="c-email" name="email" required placeholder="you@example.com" autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="c-message">Message</label>
          <textarea id="c-message" name="message" required placeholder="Questions, suggestions, partnership — all welcome"></textarea>
        </div>
        <div class="form-actions">
          <button class="btn gold" type="submit" id="contact-submit">Send</button>
          <p class="fine">By submitting you agree to our <a href="/legal/privacy/">Privacy Policy</a></p>
          <p class="form-error" id="contact-error">Sending failed — please try again later.</p>
        </div>
      </form>

      <div class="form-success" id="contact-success">
        <h2 style="margin-top:0">Message received 📨</h2>
        <p>We'll usually reply within <strong>1 business day</strong>.</p>
        <p style="margin-bottom:0"><a href="/en/">← Back to home</a></p>
      </div>

      <div class="apply-note">
        <strong>Operator</strong><br />
        Syncvalue Inc.（シンクバリュー株式会社）— corporate site: <a href="https://sync-value.com/" rel="noopener noreferrer">sync-value.com</a> · <a href="/legal/tokushoho/">Legal disclosure (ja)</a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('contact-success')!;
    const error = document.getElementById('contact-error')!;
    const btn = document.getElementById('contact-submit') as HTMLButtonElement;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      (error as HTMLElement).style.display = 'none';
      btn.disabled = true;
      btn.textContent = 'Sending…';
      fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } })
        .then((res) => {
          if (res.ok) { form.style.display = 'none'; (success as HTMLElement).style.display = 'block'; success.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
          else throw new Error('bad status');
        })
        .catch(() => { (error as HTMLElement).style.display = 'block'; btn.disabled = false; btn.textContent = 'Send'; });
    });
  </script>
</Base>
