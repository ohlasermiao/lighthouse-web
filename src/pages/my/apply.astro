---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { supabaseServer } from '../../lib/supabase';

const supabase = supabaseServer(Astro.cookies, Astro.request.headers);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/auth/login?next=/my/apply');

const email = user.email!; // 已由登录验证，保证真实可达
let sent = false;
let error = '';

function env(key: string): string | undefined {
  return (Astro.locals as any)?.runtime?.env?.[key] ?? (import.meta.env as any)[key];
}
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const name = String(form.get('name') || '').trim();
  const motivation = String(form.get('motivation') || '').trim();
  const source = String(form.get('source') || '').trim();
  if (!name || !motivation) {
    error = '请填写称呼和加入动机。';
  } else {
    const key = env('RESEND_API_KEY');
    const to = env('CONTACT_TO') || 'hello@sync-value.com';
    if (!key) {
      error = '暂时无法提交，请稍后再试。';
    } else {
      let when = '';
      try { when = new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Tokyo', dateStyle: 'medium', timeStyle: 'short' }).format(new Date()) + ' (JST)'; } catch {}
      const html = `<div style="font-family:-apple-system,'PingFang SC',sans-serif;font-size:14px;line-height:1.7;color:#232323;max-width:560px">
        <div style="background:#16314f;color:#fff;padding:14px 18px;border-radius:10px 10px 0 0;font-weight:600">Lighthouse Club · 入会申请　<span style="color:#7fd6a3">✓ 邮箱已验证</span></div>
        <div style="border:1px solid #e6ebf1;border-top:0;border-radius:0 0 10px 10px;padding:18px">
          <table style="font-size:14px;margin:0 0 8px">
            <tr><td style="color:#6b7a88;padding:2px 12px 2px 0">称呼</td><td><strong>${esc(name)}</strong></td></tr>
            <tr><td style="color:#6b7a88;padding:2px 12px 2px 0">邮箱（已验证）</td><td><a href="mailto:${esc(email)}">${esc(email)}</a></td></tr>
            ${when ? `<tr><td style="color:#6b7a88;padding:2px 12px 2px 0">提交时间</td><td>${esc(when)}</td></tr>` : ''}
          </table>
          <p><strong>加入动机：</strong></p><p style="white-space:pre-wrap;border-left:3px solid #ccc;padding-left:12px;margin:4px 0 12px">${esc(motivation)}</p>
          ${source ? `<p><strong>来源：</strong>${esc(source)}</p>` : ''}
          <p style="color:#9aa7b4;font-size:12px;border-top:1px solid #eef2f6;padding-top:10px;margin-top:14px">此申请人邮箱已通过登录验证，回信可直达（reply-to 已设为其邮箱）。</p>
        </div>
      </div>`;
      try {
        const res = await fetch('https://api.resend.com/emails', {
          method: 'POST',
          headers: { Authorization: `Bearer ${key}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ from: 'Lighthouse Club <noreply@mail.sync-value.com>', to: [to], reply_to: email, subject: `[入会申请·已验证] ${name}`, html }),
        });
        if (res.ok) sent = true; else error = '提交失败，请稍后再试。';
      } catch { error = '提交失败，请稍后再试。'; }
    }
  }
}
---
<Base title="申请加入 — Lighthouse Club" description="申请加入 Lighthouse Club。" noindex={true} routeKey="apply">
  <div class="subpage"><div class="container"><div class="account-box" style="text-align:left;max-width:520px">
    {sent ? (
      <Fragment>
        <div style="font-size:1.6rem">🎉</div>
        <h1 style="margin:.3rem 0">已收到你的申请</h1>
        <p>我们会认真阅读，并在 <strong>2 个工作日内</strong>回复到 <strong>{email}</strong>。因为你的邮箱已验证，回复一定送得到。</p>
        <p class="fine" style="margin-top:14px"><a href="/">← 回到首页</a></p>
      </Fragment>
    ) : (
      <Fragment>
        <h1 style="margin:0 0 6px">申请加入 Lighthouse Club</h1>
        <p style="margin:0 0 4px">审核结果将回复到已验证邮箱：<strong>{email}</strong></p>
        <p style="margin:0 0 24px">不是这个邮箱？<a href="/auth/signout">退出</a>后用别的邮箱重新验证。</p>
        {error && <p class="form-error" style="display:block">{error}</p>}
        <form method="POST">
          <div class="form-field">
            <label for="a-name">怎么称呼你？ *</label>
            <input type="text" id="a-name" name="name" required placeholder="昵称或称呼" autocomplete="nickname" />
          </div>
          <div class="form-field">
            <label for="a-motivation">一句话：你希望从社区获得什么？ *</label>
            <textarea id="a-motivation" name="motivation" required placeholder="交朋友、学东西、找方向、找个能安心说话的地方，都可以"></textarea>
          </div>
          <div class="form-field">
            <label for="a-source">从哪里了解到我们？<span style="font-weight:400">（选填）</span></label>
            <input type="text" id="a-source" name="source" placeholder="朋友推荐 / 社交媒体 / 其他" />
          </div>
          <div class="form-actions">
            <button class="btn gold" type="submit">提交申请</button>
            <p class="fine">提交即表示同意 <a href="/legal/tos/">服务条款</a> 与 <a href="/legal/privacy/">隐私政策</a></p>
          </div>
        </form>
      </Fragment>
    )}
  </div></div></div>
</Base>
