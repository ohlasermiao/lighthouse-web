---
import { getLangFromUrl, useT, langPrefix, altUrls } from '../i18n/ui';

interface Props { routeKey?: string }
const { routeKey } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useT(lang);
const p = langPrefix[lang];
const alts = altUrls(routeKey);
const langLabels = { zh: '中文', en: 'EN' } as const;
---
<header class="site">
  <div class="container header-inner">
    <a class="brand" href={p + '/'} aria-label="Lighthouse Club">
      <img src="/assets/img/lighthouse.svg" alt="" width="34" height="34" />
      <span class="name"><span class="en">Lighthouse Club</span><span class="tag">{t('brand.tag')}</span></span>
    </a>
    <nav class="primary" id="primary-nav" aria-label="main">
      <a href={lang === 'zh' ? '/about/' : p + '/about/'}>{t('nav.about')}</a>
      {lang === 'zh' && <a href="/inside/">{t('nav.inside')}</a>}
      <a href={lang === 'zh' ? '/pricing/' : p + '/pricing/'}>{t('nav.pricing')}</a>
      {lang === 'zh' && <a href="/faq/">{t('nav.faq')}</a>}
      {lang === 'zh' && <a href="/news/">{t('nav.news')}</a>}
      <a href="/account/">{t('nav.login')}</a>
    </nav>
    <div class="header-cta">
      <div class="lang-switch" aria-label="Language">
        {(['zh', 'en'] as const).map((l) => (
          l === lang
            ? <span class="cur" aria-current="true">{langLabels[l]}</span>
            : <a href={alts[l]}>{langLabels[l]}</a>
        ))}
      </div>
      <a class="btn gold sm" href={lang === 'zh' ? '/apply/' : p + '/apply/'}>{t('nav.apply')}</a>
      <button type="button" class="nav-toggle" aria-label={t('nav.menu')} aria-expanded="false" aria-controls="primary-nav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
